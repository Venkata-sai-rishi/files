# -----------------------------------------------
# Core
# -----------------------------------------------
OVERRIDE_HOSTNAME=mail.yourdomain.com

# -----------------------------------------------
# SSL/TLS
# -----------------------------------------------
# Use Let's Encrypt certificates mounted in docker-compose.yml
SSL_TYPE=letsencrypt

# -----------------------------------------------
# Anti-Spam / Anti-Virus
# -----------------------------------------------
# Enable SpamAssassin (Lightweight)
ENABLE_SPAMASSASSIN=1
# Disable ClamAV to save RAM (takes ~1-2GB RAM). You only have 8GB and a few mailboxes.
ENABLE_CLAMAV=0

# Enable Fail2Ban inside the mail container
ENABLE_FAIL2BAN=1

# -----------------------------------------------
# Postgrey (Greylisting)
# -----------------------------------------------
ENABLE_POSTGREY=0

# -----------------------------------------------
# DKIM / DMARC / SPF
# -----------------------------------------------
# OpenDKIM is used to sign outgoing mail
ENABLE_OPENDKIM=1
# OpenDMARC is used to verify incoming mail
ENABLE_OPENDMARC=1

# -----------------------------------------------
# Aliases
# -----------------------------------------------
# Deliver messages addressed to postmaster or root to your admin email
POSTMASTER_ADDRESS=admin@yourdomain.com
